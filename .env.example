# Required for Gemini AI API calls
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Strongly recommended in production for secure cookie signing
SESSION_SECRET="replace-this-with-a-long-random-secret"

# Optional but recommended for shared deployments.
# When set, FortuneBot will use PostgreSQL for multi-user storage.
DATABASE_URL="postgresql://user:password@host:5432/fortune_bot"

# Optional: set to disable SSL if your local Postgres instance does not use it.
PGSSL="require"

# Optional app URL used by hosted environments.
APP_URL="MY_APP_URL"
